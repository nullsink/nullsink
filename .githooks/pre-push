#!/usr/bin/env bash
# Local pre-push guard: typecheck + tests for BOTH workspace packages must pass before a
# push reaches the remote. Mirrors CI, caught one round-trip earlier.
# Enable once per clone: `git config core.hooksPath .githooks`.
# Emergency bypass: `git push --no-verify`.
set -e
echo "pre-push › typecheck (all packages)"
bun --filter '*' typecheck
echo "pre-push › test (all packages)"
bun --filter '*' test
echo "pre-push › ok"
