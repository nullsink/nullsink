{
  "name": "nullsink",
  "version": "1.7.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/nullsink/nullsink.git",
    "directory": "core"
  },
  "homepage": "https://nullsink.is",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile nullsink-linux-x64",
    "build:nsk": "bun build --compile --target=bun-linux-x64 cli/index.ts --outfile nsk-linux-x64",
    "build:all": "bun run build && bun run build:nsk",
    "e2e:capture": "bun run scripts/e2e-capture.ts",
    "e2e:hold": "bun run scripts/e2e-hold.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "fast-check": "^4.8.0",
    "typescript": "^6.0.0"
  }
}
