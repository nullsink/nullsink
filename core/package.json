{
  "name": "nullsink",
  "version": "1.10.1",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/nullsink/nullsink.git",
    "directory": "core"
  },
  "homepage": "https://nullsink.is",
  "type": "module",
  "scripts": {
    "start:proxy": "bun run src/proxy.ts",
    "start:payments": "bun run src/payments.ts",
    "dev:proxy": "bun --watch src/proxy.ts",
    "dev:payments": "bun --watch src/payments.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build:proxy": "bun build --compile --target=bun-linux-x64 --reject-unresolved --metafile=nullsink-proxy.metafile.json src/proxy.ts --outfile nullsink-proxy-linux-x64",
    "build:payments": "bun build --compile --target=bun-linux-x64 --reject-unresolved --metafile=nullsink-payments.metafile.json src/payments.ts --outfile nullsink-payments-linux-x64",
    "assert:trust-domains": "bun run scripts/assert-trust-domains.ts",
    "test:caddy": "bun run scripts/test-caddy-edge.ts",
    "build": "bun run build:proxy && bun run build:payments && bun run assert:trust-domains",
    "build:nsk": "bun build --compile --target=bun-linux-x64 cli/index.ts --outfile nsk-linux-x64",
    "e2e:capture": "bun run scripts/e2e-capture.ts",
    "e2e:hold": "bun run scripts/e2e-hold.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "fast-check": "^4.8.0",
    "typescript": "^6.0.0"
  }
}
