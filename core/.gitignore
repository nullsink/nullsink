# Ignore every .env variant (incl. odd names like ".env copy.example") except the template.
.env*
!.env.example
node_modules

# Local/test SQLite DBs (balances.db, pending.db) and their WAL sidecars + backups.
# The real ledgers live in the systemd StateDirectory, never in the repo.
*.db
*.db-wal
*.db-shm
*.bak.db

# The credit socket a locally-run `dev:proxy` binds (CREDIT_SOCK; /run/nullsink/credit.sock in prod).
*.sock

# Compiled binary build artifacts (package.json `build`/`build:nsk` / the release workflow produce them).
# The build produces two service binaries from one core; the old single-binary name is kept so a stale
# artifact from an older layout is still ignored.
/nullsink-linux-x64
/nullsink-proxy-linux-x64
/nullsink-payments-linux-x64
/nullsink-proxy.metafile.json
/nullsink-payments.metafile.json
/nsk-linux-x64
/SHA256SUMS

# Local agent working memory (notes, not project source).
memory/

# Operator scratch / point-in-time box state (stale internal notes, not project source; never published).
.state/

# mutation testing (local tooling)
.stryker-tmp/
reports/
stryker.log
