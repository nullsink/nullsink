# Caddyfile — nullsink public edge (clearnet, automatic TLS). Host-agnostic template.
#
# The served domain comes from {$NULLSINK_DOMAIN}: set NULLSINK_DOMAIN in /etc/nullsink.env and setup.sh
# feeds it to Caddy via a systemd drop-in (so this file hardcodes no host). Point that domain's A/AAAA
# record at this box. The UI web root defaults to /var/www/nullsink/current-web — the versioned-UI symlink
# deploy.sh maintains (override with NULLSINK_WEBROOT). No ACME `email` is set: Caddy issues + renews certs
# without one. Add an
# `email you@example.com` line to the global block below if you want Let's Encrypt cert-expiry notices.
#
# Design:
#   - TWO upstreams, both loopback-bound (HOST=127.0.0.1); only Caddy faces the internet.
#       :8080  nullsink-proxy    — the prompt world: /v1/* + /balance
#       :8081  nullsink-payments — the payment world: /buy + /order-status + /rails
#     The two processes separate privilege: a request that carries a prompt never reaches the process that
#     holds the payment→token link, and vice versa. Route each path to exactly one upstream — there is no
#     shared router behind these ports, so a misrouted path is a hard 404, not a silent cross-world call.
#   - Public surface = the static UI + POST /v1/messages + POST /v1/chat/completions + POST /v1/responses + GET /v1/models
#     + GET /v1/models + GET /balance + POST /buy + POST /order-status + GET /rails.
#   - /buy IS routed: a browser-side UI can only call a reachable endpoint, and we run no server-side BFF,
#     so /buy is publicly reachable. That's fine: /buy hands out a payment address, not free value, and is
#     bounded by the app's resource caps. No CAPTCHA/PoW gate (decided). We simply don't advertise it.
#     (Taking /buy genuinely off the public net would need a BFF — a different design.)
#   - NO `log` directive → Caddy keeps no access logs / no client IPs. Access logging is off by default
#     in Caddy v2; this comment makes the no-identity intent explicit. Don't add `log` without thought.
{
	# Slow-loris guard: bound how long a client may take to send request HEADERS and the full request BODY.
	# read_body maps to Go's ReadTimeout (the whole-request READ deadline); it does NOT bound response WRITES,
	# so long SSE generations on /v1/messages (streamed for up to UPSTREAM_TIMEOUT_MS, ~10min) are unaffected.
	# 5m tolerates a 32 MiB multimodal upload over a slow link while still cutting a dribble (slow-body)
	# attack. Do NOT add a `write` timeout here: it WOULD cut a long generation. flush_interval -1 (below)
	# keeps SSE flushing immediately regardless.
	servers {
		timeouts {
			read_header 15s
			read_body 5m
		}
	}
}

{$NULLSINK_DOMAIN} {
	# --- Security headers ---
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		# The token is the customer's money: no third-party script may ever load on the page that
		# holds it. Everything is same-origin (UI + /buy + /balance + /v1 on the one domain), so a
		# strict default-src 'self' needs no carve-outs — the built UI self-hosts fonts (@fontsource)
		# and the QR (bundled qrcode-generator), no CDN. base-uri 'none' is load-bearing, not cosmetic:
		# the UI fetches /balance with a RELATIVE url, so an injected <base> could redirect that request
		# (and the raw token) to an attacker origin — this forbids it. frame-ancestors/X-Frame-Options
		# stop clickjacking. Applied site-wide (incl. API routes); harmless on JSON, defence in depth.
		Content-Security-Policy "default-src 'self'; base-uri 'none'; form-action 'self'; frame-ancestors 'none'; object-src 'none'"
		X-Frame-Options "DENY"
		# The page uses no powerful browser APIs, so deny them all (defence in depth). payment=() forbids
		# the browser Payment Request API — irrelevant here since funding is on-chain XMR/BTC, but explicit is better.
		Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=(), usb=()"
		-Server
	}

	# --- Metered API. Large multimodal prompts allowed; SSE streamed through untouched. ---
	handle /v1/messages {
		# Caddy enforces max_size on the ACTUAL bytes received, so this also closes the
		# chunked-transfer bypass that the app's content-length-header check misses.
		request_body {
			max_size 32MiB
		}
		reverse_proxy 127.0.0.1:8080 {
			flush_interval -1 # stream SSE immediately, no response buffering (long generations)
			header_up -X-Forwarded-For # don't hand the client IP to the app (no-identity thesis)
		}
	}

	# --- Metered API (OpenAI Chat Completions + Responses). Same treatment as /v1/messages; the app 404s
	#     these when OPENAI_API_KEY is unset, so routing them is harmless before the provider is enabled. ---
	handle /v1/chat/completions {
		request_body {
			max_size 32MiB
		}
		reverse_proxy 127.0.0.1:8080 {
			flush_interval -1 # stream SSE immediately, no response buffering (long generations)
			header_up -X-Forwarded-For # don't hand the client IP to the app (no-identity thesis)
		}
	}

	handle /v1/responses {
		request_body {
			max_size 32MiB
		}
		reverse_proxy 127.0.0.1:8080 {
			flush_interval -1
			header_up -X-Forwarded-For
		}
	}

	# --- Model catalog (GET, unauthenticated free read — the one /v1 path that isn't a metered forward; the
	#     app applies the shared read throttle, same as /rails). No body, so no request_body cap. ---
	handle /v1/models {
		reverse_proxy 127.0.0.1:8080 {
			header_up -X-Forwarded-For
		}
	}

	# --- Balance check (API clients + the UI poll this). ---
	handle /balance {
		reverse_proxy 127.0.0.1:8080 {
			header_up -X-Forwarded-For
		}
	}

	# --- Credit purchase (called by the UI). Tiny JSON body. PAYMENT WORLD -> :8081. ---
	handle /buy {
		request_body {
			max_size 4KB
		}
		reverse_proxy 127.0.0.1:8081 {
			header_up -X-Forwarded-For
		}
	}

	# --- Order status (the UI polls a pending payment's progress, keyed by the token HASH — never the
	#     raw token). Tiny JSON body, same as /buy; reveals no balance. PAYMENT WORLD -> :8081. ---
	handle /order-status {
		request_body {
			max_size 4KB
		}
		reverse_proxy 127.0.0.1:8081 {
			header_up -X-Forwarded-For
		}
	}

	# --- Active pay rails (the UI picker reads this to render the coin choices; reveals only which coins
	#     we accept — already public on the marketing pages). Tiny GET, no body, no balance.
	#     PAYMENT WORLD -> :8081. ---
	handle /rails {
		reverse_proxy 127.0.0.1:8081 {
			header_up -X-Forwarded-For
		}
	}

	# --- Everything else → the static purchase UI. (/healthz is intentionally NOT routed; BOTH services
	#     expose it as a localhost-only liveness check, so public requests for it just 404 here.) ---
	handle {
		root * {$NULLSINK_WEBROOT:/var/www/nullsink/current-web}
		encode gzip zstd
		file_server
	}

	# --- Edge error contract. reverse_proxy passes an upstream's 4xx/5xx response through unchanged; this
	#     runs only when Caddy itself cannot reach a split service. SDK routes must keep their provider-native
	#     envelope and say retryable, while site routes keep nullsink's small own-endpoint envelope. ---
	handle_errors {
		@anthropic_outage path /v1/messages
		handle @anthropic_outage {
			header x-should-retry "true"
			respond `{"type":"error","error":{"type":"api_error","message":"service_unavailable"}}` 503
		}

		@openai_outage path /v1/chat/completions /v1/responses
		handle @openai_outage {
			header x-should-retry "true"
			respond `{"error":{"message":"service_unavailable","type":"server_error","code":"service_unavailable"}}` 503
		}

		@proxy_outage path /v1/models /balance
		handle @proxy_outage {
			respond `{"error":"proxy_error"}` 503
		}

		@payments_outage path /buy /order-status /rails
		handle @payments_outage {
			respond `{"error":"payments_error"}` 503
		}

		# file_server raises a 404 for an unknown static path. Serve the prerendered page but KEEP its 404
		# status. API 404s from an upstream are successful proxy responses and never arrive here.
		@404 expression {err.status_code} == 404
		handle @404 {
			root * {$NULLSINK_WEBROOT:/var/www/nullsink/current-web}
			rewrite * /404.html
			file_server {
				status 404
			}
		}
	}
}
