# nullsink configuration — every supported var, grouped by area. At least one provider key
# (ANTHROPIC_API_KEY, OPENAI_API_KEY, or TINFOIL_API_KEY) is required; every other line shows its default, so an unset
# var behaves exactly as written here.
#
# Local dev:  cp .env.example .env  then  bun run dev   (Bun loads .env)
# Production: setup.sh templates /etc/nullsink.env and systemd reads it as an EnvironmentFile.
#
# Comments stay on their OWN lines, never inline after a value — so this file is safe to copy
# anywhere (systemd keeps everything after `=` as the value; an inline `# ...` would corrupt it).

# === Providers (set at least one key) ===

# Anthropic: set a key to serve POST /v1/messages. The proxy injects it; clients never see it.
ANTHROPIC_API_KEY=sk-ant-...
# Anthropic upstream — override only for testing.
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

# OpenAI: set a key to serve POST /v1/chat/completions + /v1/responses.
# The same key gates the count_tokens call and the forward; balances are shared across providers.
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com

# Tinfoil: set a key to serve open-weight models (confidential-compute / TEE, OpenAI-compatible) on
# POST /v1/chat/completions, alongside OpenAI on that path — requests route by model id, or an explicit
# `tinfoil/<model>` prefix. No count_tokens endpoint, so its hold always uses the byte bound
# (HOLD_ESTIMATOR is ignored for Tinfoil).
TINFOIL_API_KEY=tk_...
# Host root (no path — the provider appends /v1/chat/completions). On a deployed box, setup.sh installs
# tinfoil-proxy.service and defaults this to the local verifying proxy (enclave attestation),
# http://127.0.0.1:3301, when a key is present and this is left unset. An explicit value is respected on re-runs:
# the public endpoint below forwards directly, WITHOUT attestation (fine for local dev).
TINFOIL_BASE_URL=https://inference.tinfoil.sh

# === Server ===
#
# nullsink runs as TWO processes that share this file, each reading only the vars it needs:
#   nullsink-proxy    (src/proxy.ts)    — the metered /v1 paths + /balance; owns balances.db
#   nullsink-payments (src/payments.ts) — /buy, /order-status, /rails; owns pending.db + the pay rails
# Credits cross from payments to the proxy over a unix socket (CREDIT_SOCK), never a shared database.
# Locally, run them in two terminals: `bun run dev:proxy` and `bun run dev:payments`.

# Bind address, shared by both services (Caddy fronts them in prod). Set 0.0.0.0 only for LAN dev.
HOST=127.0.0.1
# One loopback port per service. Caddy routes each public path to exactly one of them; change either and the
# Caddyfile's matching reverse_proxy line together.
PORT=8080
PAYMENTS_PORT=8081

# === The credit crossing (payments -> proxy) ===

# The unix socket the proxy binds and payments connects to. It is bound owner-only, and connect(2) requires
# write permission on the socket FILE — that kernel-enforced check is the authentication, so this must stay a
# pathname socket on a directory only the service user can traverse. In prod systemd sets
# /run/nullsink/credit.sock; this dev-local path is gitignored.
CREDIT_SOCK=./credit.sock
# Per-credit socket round-trip timeout. On timeout the credit stays durable in the outbox and retries — a
# slow proxy delays a credit, it never loses one.
CREDIT_TIMEOUT_MS=5000
# Alert (a greppable "CREDIT OUTBOX STALLED" ERROR, watched by deploy/status-check.sh) when the oldest
# undelivered credit is older than this. Neither /healthz can see a wedged socket; this is the "is money
# still crossing?" signal, so keep it well under a support-ticket's worth of time.
OUTBOX_AGE_ALERT_MS=600000

# === Upstream forwarding ===

# Abort a hung upstream request after this many ms.
UPSTREAM_TIMEOUT_MS=600000
# Force-settle a streaming hold whose client opens but never reads/closes.
# Must be > UPSTREAM_TIMEOUT_MS (min-clamped to +1).
STREAM_SETTLE_DEADLINE_MS=660000

# === Hold sizing (pre-flight) ===

# count_tokens = exact input tokens (1 extra call, fails safe to byte bound); byte = deterministic, no call.
HOLD_ESTIMATOR=count_tokens
# Timeout for the count_tokens call (when HOLD_ESTIMATOR=count_tokens).
COUNT_TOKENS_TIMEOUT_MS=10000
# Output cap injected when a request omits one (so stock OpenAI clients work). 0 = require an explicit cap.
# Set e.g. 16384, kept <= the smallest max-output you serve. Moot for Anthropic (its API requires max_tokens).
DEFAULT_MAX_OUTPUT_TOKENS=0

# === Request size caps (DoS) ===

# /v1/messages ceiling — 32 MiB, matching the upstream's binary-MiB request limit (not decimal 32 MB).
MAX_MESSAGES_BODY_BYTES=33554432
# /buy bodies are tiny.
MAX_BUY_BODY_BYTES=4096

# === Rate limits (global, identity-free — no IP/token tracking) ===

# /buy: burst size + sustained requests/min. Read by nullsink-payments only.
BUY_RATE_CAPACITY=20
BUY_RATE_REFILL_PER_MIN=60
# Free reads: burst + sustained/min (3000 = 50/s). Metered endpoints have no bucket.
# PER SERVICE, not global: each process reads these and builds its OWN bucket — the proxy's covers /balance,
# payments' covers /order-status + /rails — so the aggregate free-read capacity is TWICE what you set here.
# Halved from the pre-split 120/6000 so that aggregate is unchanged.
READ_RATE_CAPACITY=60
READ_RATE_REFILL_PER_MIN=3000

# === Storage (SQLite) ===

# One database per world, and neither process opens the other's: nullsink-proxy owns the token-balance ledger,
# nullsink-payments owns the in-flight orders + sales book + credit outbox. BACK UP BOTH — losing balances.db
# means refunding everyone, and losing pending.db strands paid-but-uncredited orders.
#
# DEV-LOCAL PATHS (gitignored). In prod the units set /var/lib/nullsink/* via Environment=, and setup.sh's
# templated /etc/nullsink.env deliberately does NOT carry these lines — because systemd's EnvironmentFile=
# OVERRIDES Environment=, not the other way round. So never paste this file wholesale into /etc/nullsink.env:
# a relative DB_PATH there would win over the unit. (It would fail loudly rather than corrupt anything —
# ProtectSystem=strict makes the working directory read-only — but the box would crash-loop.) The same holds
# for CREDIT_SOCK above.
DB_PATH=./balances.db
PENDING_DB_PATH=./pending.db

# === Observability ===

# How often the aggregate [metrics] line is emitted + the window resets (hourly).
METRICS_FLUSH_MS=3600000

# === Shutdown ===

# SIGTERM grace for in-flight requests before force-settle. Read by nullsink-proxy (the only service with
# long-lived streams). Keep < nullsink-proxy.service's TimeoutStopSec.
SHUTDOWN_GRACE_MS=25000

# ============================================================================
# Buy rails (POST /buy) — optional; live + public, fronted by the UI.
# PAY_RAILS is a comma list of active rails; the FIRST is the /buy default (legacy PAY_RAIL=<one> still
# resolves). Each rail needs its watcher: Monero a view-only monero-wallet-rpc + node; Bitcoin a pruned
# watch-only bitcoind. Each reads only its own *_CONFIRMATIONS (no shared fallback).
# ============================================================================

PAY_RAILS=monero

# --- Monero rail ---
# View-only wallet-rpc (localhost, login off).
MONERO_WALLET_RPC_URL=http://127.0.0.1:18083/json_rpc
# Wallet account to derive per-order subaddresses in.
MONERO_ACCOUNT_INDEX=0
# Wallet-rpc call timeout.
MONERO_TIMEOUT_MS=30000
# XMR blocks before crediting (~10 is the floor — outputs lock ~10 blocks).
MONERO_CONFIRMATIONS=10

# --- Bitcoin rail (only used when `bitcoin` is in PAY_RAILS) ---
# bitcoind wallet RPC endpoint. Port is 8332 on mainnet; a signet/testnet box uses 38332.
BITCOIN_RPC_URL=http://127.0.0.1:8332/wallet/nullsink
# rpcauth user + the plaintext that hashes to the conf's rpcauth= line
# (deploy/regen-bitcoin-rpcauth.sh keeps them matched; leave the password empty until then).
BITCOIN_RPC_USER=nullsink
BITCOIN_RPC_PASSWORD=
# BTC blocks before crediting.
BITCOIN_CONFIRMATIONS=3
# bitcoind RPC call timeout.
BITCOIN_TIMEOUT_MS=30000

# --- Exchange rates ---
# Ordered failover list of built-in source names (registry in src/rails/rate.ts). First in-band price wins;
# the rest are availability failover. One source works but is a SPOF for the sole purchasing path.
RATE_SOURCES=kraken,coingecko
# Source URLs (XMR): kraken primary + coingecko fallback.
RATE_URL=https://api.kraken.com/0/public/Ticker?pair=XMRUSD
RATE_URL_COINGECKO=https://api.coingecko.com/api/v3/simple/price?ids=monero&vs_currencies=usd
# Source URLs (BTC): own band since BTC trades far above XMR.
BTC_RATE_URL=https://api.kraken.com/0/public/Ticker?pair=XBTUSD
BTC_RATE_URL_COINGECKO=https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=usd
# Per-source fetch timeout + how long a fetched rate is cached before refetch.
RATE_TIMEOUT_MS=10000
RATE_CACHE_MS=60000
# Sane bands: a parse error / manipulated source outside [min,max] is rejected.
RATE_MIN_USD=1
RATE_MAX_USD=100000
BTC_RATE_MIN_USD=1000
BTC_RATE_MAX_USD=10000000

# --- Pricing + limits ---
# Buyer pays credit_usd × MARGIN (1.10 = 10% markup).
MARGIN=1.10
# Min / max credit per /buy.
BUY_MIN_USD=2
BUY_MAX_USD=2000

# --- Order lifecycle + settlement ---
# Settlement poll cadence.
POLL_INTERVAL_MS=30000
# Consecutive failed poll ticks (one rail) before escalating to an alertable "POLL BLIND" ERROR.
POLL_FAIL_ALERT=5
# Buyer's "pay by" deadline (4h; floor 5m).
ORDER_TTL_MS=14400000
# Slack before reaping an unfunded order, for a near-deadline payment's first confirmation (30m).
REAP_GRACE_MS=1800000
# Absolute safety net: reap ANY order older than this (24h). Keep > ORDER_TTL_MS + REAP_GRACE_MS.
ORDER_BACKSTOP_MS=86400000
# Global in-flight order ceiling.
MAX_OPEN_ORDERS=1000

# ============================================================================
# Deploy / ops — consumed by the box's systemd units + deploy/ scripts, NOT the app. In prod these live
# in /etc/nullsink.env (templated by setup.sh); they are irrelevant to local dev and safe to ignore there.
# (The XMR node-over-Tor toggle MONERO_PROXY_ARG lives in /etc/monero-wallet-rpc.env, not here.)
# ============================================================================

# Public edge: the domain Caddy serves on. setup.sh feeds it to Caddy via a drop-in; EMPTY = no public edge.
# Read by setup.sh/Caddy only — the app never reads it.
NULLSINK_DOMAIN=
# Caddy webroot for the client UI (override rarely needed).
NULLSINK_WEBROOT=/var/www/nullsink/current-web

# --- Telegram health alerts (status-check OnFailure) ---
# EMPTY = alerts disabled (safe no-op). Bot token from @BotFather, numeric chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Dead-man's-switch ping (status-check) ---
# A healthchecks.io / Uptime Kuma push URL, pinged on success so an OFF-BOX monitor alerts if pings STOP.
# EMPTY = disabled.
HEARTBEAT_URL=

# --- Backups (deploy/backup.sh, daily via backup.timer) ---
# OFF-BOX copies MUST be encrypted: set an age PUBLIC key whose private key you keep OFFLINE (the box can
# only encrypt). EMPTY = local-only plaintext snapshots (fine on-box; never push those off).
BACKUP_AGE_RECIPIENT=
# Shell snippet to ship each finished artifact off-box, run with $ARTIFACT = the file path, e.g.:
#   BACKUP_PUSH_CMD=rclone copy "$ARTIFACT" remote:nullsink-backups/
# EMPTY = keep backups on-box only.
BACKUP_PUSH_CMD=
# Advanced (defaults shown): artifact dir, how many to keep, allow pushing PLAINTEXT off-box (1 = yes).
BACKUP_DIR=/var/lib/nullsink/backups
BACKUP_KEEP=14
BACKUP_PUSH_ALLOW_PLAINTEXT=0
# Restore-time only (deploy/restore.sh): path to your OFFLINE age private key to decrypt a backup.
# Do NOT store this on the box — supply it only when restoring. Shown for reference.
#BACKUP_AGE_IDENTITY=
